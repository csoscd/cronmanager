{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB 2.x datasource (Flux query language)",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",   "name": "Grafana",   "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb",  "name": "InfluxDB",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",      "name": "Stat",      "version": ""        },
    { "type": "panel",      "id": "gauge",     "name": "Gauge",     "version": ""        },
    { "type": "panel",      "id": "timeseries","name": "Time series","version": ""       },
    { "type": "panel",      "id": "table",     "name": "Table",     "version": ""        },
    { "type": "panel",      "id": "barchart",  "name": "Bar chart", "version": ""        }
  ],
  "annotations": { "list": [] },
  "description": "Cronmanager – cron job execution metrics. Requires InfluxDB 2.x with Flux query language.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1, "title": "Overview", "type": "row" },

    {
      "id": 2,
      "title": "Total Executions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\")\n  |> count()\n  |> sum()",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null },
            { "color": "yellow","value": 80   },
            { "color": "green", "value": 95   }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "total = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\")\n  |> count()\n  |> sum()\n  |> map(fn: (r) => ({r with _field: \"total\"}))\n\nsuccess = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\" and r.status == \"success\")\n  |> count()\n  |> sum()\n  |> map(fn: (r) => ({r with _field: \"success\"}))\n\nunion(tables: [total, success])\n  |> pivot(rowKey: [\"_stop\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({r with _value: if r.total > 0 then float(v: r.success) / float(v: r.total) * 100.0 else 0.0}))",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "Failed Executions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\" and r.status == \"failed\")\n  |> count()\n  |> sum()",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "title": "Avg Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"duration_seconds\" and r.status == \"success\")\n  |> mean()",
        "refId": "A"
      }]
    },

    {
      "id": 6,
      "title": "Skipped (Maintenance)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "gray" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "gray", "value": null }] } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\" and r.status == \"maintenance\")\n  |> count()\n  |> sum()",
        "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10, "title": "Trends", "type": "row" },

    {
      "id": 11,
      "title": "Executions over Time (by Status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" }, "lineWidth": 0, "fillOpacity": 80 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success"      }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed"       }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "maintenance"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#A9A9A9", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "killed"       }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "interrupted"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#B0B0B0", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "limit_exceeded"}, "properties":[{ "id": "color", "value": { "fixedColor": "#FF780A", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\")\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> group(columns: [\"status\"])\n  |> map(fn: (r) => ({r with _field: r.status}))",
        "refId": "A"
      }]
    },

    {
      "id": 12,
      "title": "Execution Duration over Time (avg per job)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"duration_seconds\" and r.status == \"success\")\n  |> group(columns: [\"description\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _field: r.description}))",
        "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20, "title": "Job Breakdown", "type": "row" },

    {
      "id": 21,
      "title": "Executions by Job",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 80 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed"   }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\")\n  |> group(columns: [\"description\", \"status\"])\n  |> count()\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 20)",
        "refId": "A"
      }]
    },

    {
      "id": 22,
      "title": "Avg Duration by Job (successful runs)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 80 }, "color": { "fixedColor": "#5794F2", "mode": "fixed" } } },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"duration_seconds\" and r.status == \"success\")\n  |> group(columns: [\"description\"])\n  |> mean()\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 20)",
        "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30, "title": "Recent Failures", "type": "row" },

    {
      "id": 31,
      "title": "Recent Failed Executions",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": { "sortBy": [{ "desc": true, "displayName": "Time" }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "exit_code"       }, "properties": [{ "id": "displayName", "value": "Exit Code"   }] },
          { "matcher": { "id": "byName", "options": "duration_seconds"}, "properties": [{ "id": "displayName", "value": "Duration (s)" }, { "id": "unit", "value": "s" }] },
          { "matcher": { "id": "byName", "options": "description"     }, "properties": [{ "id": "displayName", "value": "Job"          }] },
          { "matcher": { "id": "byName", "options": "linux_user"      }, "properties": [{ "id": "displayName", "value": "User"         }] },
          { "matcher": { "id": "byName", "options": "target"          }, "properties": [{ "id": "displayName", "value": "Target"       }] },
          { "matcher": { "id": "byName", "options": "status"          }, "properties": [{ "id": "displayName", "value": "Status"       }, { "id": "custom.width", "value": 100 }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"exit_code\" and r.status == \"failed\")\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 50)\n  |> keep(columns: [\"_time\", \"description\", \"linux_user\", \"target\", \"status\", \"_value\"])\n  |> rename(columns: {_value: \"exit_code\"})",
        "refId": "A"
      }, {
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cron_execution\" and r._field == \"duration_seconds\" and r.status == \"failed\")\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 50)\n  |> keep(columns: [\"_time\", \"description\", \"_value\"])\n  |> rename(columns: {_value: \"duration_seconds\"})",
        "refId": "B"
      }],
      "transformations": [{ "id": "merge", "options": {} }]
    }

  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["cronmanager", "cron", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_INFLUXDB",
        "options": [],
        "query": "influxdb",
        "refresh": 1,
        "type": "datasource",
        "label": "InfluxDB datasource"
      },
      {
        "current": { "selected": false, "text": "cronmanager", "value": "cronmanager" },
        "hide": 0,
        "name": "bucket",
        "label": "Bucket",
        "options": [{ "selected": true, "text": "cronmanager", "value": "cronmanager" }],
        "query": "cronmanager",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cronmanager – Execution Overview",
  "uid": "cronmanager-overview",
  "version": 1
}
